    "code": "def forward(self, samples):",
    "comment_zh": "展示 BLIP-2 第一阶段图文对齐；片段已简化。"
   },
   {
    "code": "    image = samples['image']",
    "comment_zh": "读取预处理后的图像批次。"
   },
   {
    "code": "    with self.maybe_autocast():",
    "comment_zh": "视觉编码器可使用混合精度以节省显存。"
   },
   {
    "code": "        image_embeds = self.ln_vision(self.visual_encoder(image))",
    "comment_zh": "冻结视觉编码器输出 patch 特征并归一化。"
   },
   {
    "code": "    image_atts = torch.ones(image_embeds.size()[:-1], dtype=torch.long)",
    "comment_zh": "为全部有效图像 token 创建注意力掩码。"
   },
   {
    "code": "    query_tokens = self.query_tokens.expand(image_embeds.shape[0], -1, -1)",
    "comment_zh": "为批内每张图复制同一组可学习查询。"
   },
   {
    "code": "    query_output = self.Qformer.bert(",
    "comment_zh": "让查询通过 Q-Former 读取视觉特征。"
   },
   {
    "code": "        query_embeds=query_tokens,",
    "comment_zh": "查询作为 Q-Former 的输入 token。"
   },
   {
    "code": "        encoder_hidden_states=image_embeds,",
    "comment_zh": "冻结视觉特征作为交叉注意力的键和值。"
   },
   {
    "code": "        encoder_attention_mask=image_atts,",
    "comment_zh": "告知交叉注意力哪些视觉 token 有效。"
   },
   {
    "code": "        use_cache=True, return_dict=True",
    "comment_zh": "缓存查询状态并以字典形式返回。"
   },
   {
    "code": "    )",
    "comment_zh": "完成视觉查询过程。"
   },
   {
    "code": "    image_feats = F.normalize(",
    "comment_zh": "把查询输出投影到图文对比空间。"
   },
   {
    "code": "        self.vision_proj(query_output.last_hidden_state), dim=-1",
    "comment_zh": "每个 query 都得到一个归一化视觉向量。"
   },
   {
    "code": "    )",
    "comment_zh": "结束图像特征归一化。"
   },
   {
    "code": "    text_tokens = self.tokenizer(samples['text_input'], return_tensors='pt', padding=True)",
    "comment_zh": "对配对文本分词并补齐。"
   },
   {
    "code": "    text_output = self.Qformer.bert(text_tokens.input_ids, attention_mask=text_tokens.attention_mask)",
    "comment_zh": "Q-Former 的文本路径编码句子。"
   },
   {
    "code": "    text_feat = F.normalize(self.text_proj(text_output.last_hidden_state[:, 0, :]), dim=-1)",
    "comment_zh": "取文本 CLS 并投影到同一空间。"
   },
